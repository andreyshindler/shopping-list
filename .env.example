# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Postgres credentials (used by the db service and DATABASE_URL below)
POSTGRES_USER=shopping
POSTGRES_PASSWORD=change-me
POSTGRES_DB=shopping

# SQLAlchemy connection string (host "db" matches the compose service)
DATABASE_URL=postgresql+psycopg://shopping:change-me@db:5432/shopping

# Public URL where the web app is reachable — used in the links the bot sends
WEB_BASE_URL=https://shop.example.com

# Port the web service publishes on the host
WEB_PORT=8000

# Default currency for new users (override per user with /currency)
DEFAULT_CURRENCY=USD

# Receipt scanning via Claude vision. Leave ANTHROPIC_API_KEY empty to disable the
# "Scan receipt" feature. Get a key at https://console.anthropic.com/.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Global price feed (Shufersal) for the daily price-fetch job (app.jobs.fetch_prices)
SHUFERSAL_STORE_ID=7290027600007
PRICE_FETCH_MAX_FILES=5
GLOBAL_PRICE_CURRENCY=ILS
